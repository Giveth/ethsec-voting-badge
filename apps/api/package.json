{
  "name": "@ethsec/api",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@ethsec/shared": "workspace:*",
    "@fastify/cors": "^9.0.0",
    "@fastify/rate-limit": "^9.1.0",
    "drizzle-orm": "^0.33.0",
    "fastify": "^4.28.0",
    "pg": "^8.20.0",
    "viem": "^2.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@noble/post-quantum": "^0.2.1",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.24.0",
    "pg-mem": "^3.0.14",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
}
