    "zod": "^3.23.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.24.0",
    "tsx": "^4.16.0",
    "vitest": "^1.6.0",
    "@types/node": "^20.11.0",
    "typescript": "^5.5.0"
  }
